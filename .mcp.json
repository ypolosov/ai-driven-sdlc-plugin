{
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {}
    },
    "essence-alpha": {
      "type": "stdio",
      "command": "essence-alpha-mcp",
      "args": [
        "serve"
      ],
      "env": {
        "ESSENCE_ALPHA_DB": "${CLAUDE_PROJECT_DIR}/.claude/sdlc/essence-alpha.db"
      }
    }
  }
}
